USE GeoPlay;

INSERT INTO Districts ([
  {"id":1, "name":"District5",      "region": st_geom_from_text("POLYGON((1 1,5 1,5 5,1 5,1 1))")},
  {"id":2, "name":"District10",     "region": st_geom_from_text("POLYGON((1 1,10 1,10 10,1 10,1 1))")},
  {"id":3, "name":"RemoteDistrict", "region": st_geom_from_text("POLYGON((50 50,60 50,60 60,50 60,50 50))")}
]);

INSERT INTO Buildings ([
  {"id":1, "address":"200 2nd Street",  "location": st_geom_from_text("POINT(2 2)")},
  {"id":2, "address":"900 Main Street", "location": st_geom_from_text("POINT(9 9)")}
]);
