-- Self-join: detect overlapping districts via st_intersects
-- District5 lies within District10, so they intersect; RemoteDistrict does not intersect either
-- Expected: 1 row (D1, D2)
USE GeoPlay;
SELECT d1.id AS id1, d1.name AS name1, d2.id AS id2, d2.name AS name2
FROM Districts d1, Districts d2
WHERE st_intersects(d1.region, d2.region) AND d1.id < d2.id
ORDER BY d1.id, d2.id;
