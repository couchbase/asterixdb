-- LOJ with COUNT aggregation: count buildings per district including zero-match districts
-- Expected: D1->1, D2->2, D3->0
USE GeoPlay;
SELECT dist.id AS did, dist.name AS dname, COUNT(bldg.id) AS cnt
FROM Districts dist LEFT OUTER JOIN Buildings bldg
  ON st_contains(dist.region, bldg.location)
GROUP BY dist.id, dist.name
ORDER BY dist.id;
