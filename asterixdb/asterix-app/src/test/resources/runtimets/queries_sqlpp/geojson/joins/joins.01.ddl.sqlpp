DROP DATAVERSE GeoPlay IF EXISTS;
CREATE DATAVERSE GeoPlay;
USE GeoPlay;

CREATE TYPE DistrictType AS { id: int, name: string, region: geometry };
CREATE TYPE BuildingType AS { id: int, address: string, location: geometry };

CREATE DATASET Districts (DistrictType) PRIMARY KEY id;
CREATE DATASET Buildings (BuildingType) PRIMARY KEY id;

CREATE INDEX distIndex ON Districts(region) TYPE rtree;
CREATE INDEX bldgIndex ON Buildings(location) TYPE rtree;
