-- Correlated subquery: original ASTERIXDB-3730 bug scenario
-- st_contains must not receive MISSING from outer LOJ plan
-- Expected: D1->[B1], D2->[B1,B2], D3->[]
USE GeoPlay;
SELECT dist.id AS did, dist.name AS dname,
  (SELECT VALUE bldg
   FROM Buildings bldg
   WHERE st_contains(dist.region, bldg.location)
   ORDER BY bldg.id) AS dbldgs
FROM Districts dist
ORDER BY dist.id;
