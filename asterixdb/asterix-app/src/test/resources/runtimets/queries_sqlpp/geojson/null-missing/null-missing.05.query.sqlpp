/* Standalone concrete descriptor functions with NULL in every argument position.
   All must return NULL. */
{
  /* STBufferDescriptor (geom, distance) */
  "st_buffer_0":                  st_buffer(null, 1.0),
  "st_buffer_1":                  st_buffer(st_geom_from_text("POINT(0 0)"), null),
  /* STDWithinDescriptor (geom0, geom1, distance) */
  "st_dwithin_0":                 st_dwithin(null, st_geom_from_text("POINT(1 0)"), 2.0),
  "st_dwithin_1":                 st_dwithin(st_geom_from_text("POINT(0 0)"), null, 2.0),
  "st_dwithin_2":                 st_dwithin(st_geom_from_text("POINT(0 0)"), st_geom_from_text("POINT(1 0)"), null),
  /* STRelateDescriptor (geom0, geom1, matrix) */
  "st_relate_0":                  st_relate(null, st_geom_from_text("POINT(1 0)"), "FF2FF1FF2"),
  "st_relate_1":                  st_relate(st_geom_from_text("POINT(0 0)"), null, "FF2FF1FF2"),
  "st_relate_2":                  st_relate(st_geom_from_text("POINT(0 0)"), st_geom_from_text("POINT(1 0)"), null),
  /* STGeomFromTextSRIDDescriptor (wkt_string, srid) */
  "st_geom_from_text_srid_0":     st_geom_from_text(null, 4326),
  "st_geom_from_text_srid_1":     st_geom_from_text("POINT(0 0)", null),
  /* STMakePointDescriptor (x, y) */
  "st_make_point_0":              st_make_point(null, 0.0),
  "st_make_point_1":              st_make_point(0.0, null),
  /* STMakePoint3DDescriptor (x, y, z) */
  "st_make_point3d_0":            st_make_point(null, 0.0, 0.0),
  "st_make_point3d_1":            st_make_point(0.0, null, 0.0),
  "st_make_point3d_2":            st_make_point(0.0, 0.0, null),
  /* STMakePoint3DWithMDescriptor (x, y, z, m) */
  "st_make_point3dm_0":           st_make_point(null, 0.0, 0.0, 0.0),
  "st_make_point3dm_1":           st_make_point(0.0, null, 0.0, 0.0),
  "st_make_point3dm_2":           st_make_point(0.0, 0.0, null, 0.0),
  "st_make_point3dm_3":           st_make_point(0.0, 0.0, 0.0, null),
  /* STMakeEnvelopeDescriptorSRID (xmin, ymin, xmax, ymax, srid) */
  "st_make_envelope_0":           st_make_envelope(null, 0.0, 1.0, 1.0, 4326),
  "st_make_envelope_1":           st_make_envelope(0.0, null, 1.0, 1.0, 4326),
  "st_make_envelope_2":           st_make_envelope(0.0, 0.0, null, 1.0, 4326),
  "st_make_envelope_3":           st_make_envelope(0.0, 0.0, 1.0, null, 4326),
  "st_make_envelope_4":           st_make_envelope(0.0, 0.0, 1.0, 1.0, null)
};
