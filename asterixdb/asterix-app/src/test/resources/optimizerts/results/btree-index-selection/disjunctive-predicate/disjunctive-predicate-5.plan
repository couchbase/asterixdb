distribute result [$$x]
-- DISTRIBUTE_RESULT  |UNPARTITIONED|
  exchange
  -- ONE_TO_ONE_EXCHANGE  |UNPARTITIONED|
    limit 2
    -- STREAM_LIMIT  |UNPARTITIONED|
      exchange
      -- RANDOM_MERGE_EXCHANGE  |PARTITIONED|
        limit 2
        -- STREAM_LIMIT  |PARTITIONED|
          assign [$$22] <- [$$x.getField(1)] project: [$$x]
          -- ASSIGN  |PARTITIONED|
            project ([$$x])
            -- STREAM_PROJECT  |PARTITIONED|
              exchange
              -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                unnest-map [$$23, $$x] <- index-search("TestSet", 0, "Default", "test", "TestSet", false, false, 1, $$28, 1, $$28, true, true, true) condition (or(eq($$x.getField(1), "one"), eq($$x.getField(1), "two"), eq($$x.getField(1), "two"))) limit 2
                -- BTREE_SEARCH  |PARTITIONED|
                  exchange
                  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                    order (ASC, $$28)
                    -- STABLE_SORT [$$28(ASC)]  |PARTITIONED|
                      exchange
                      -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                        project ([$$28])
                        -- STREAM_PROJECT  |PARTITIONED|
                          exchange
                          -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                            unnest-map [$$27, $$28] <- index-search("TestSetIndex", 0, "Default", "test", "TestSet", false, false, 1, $$25, 1, $$25, true, true, true)
                            -- BTREE_SEARCH  |PARTITIONED|
                              exchange
                              -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                unnest $$25 <- scan-collection(array: [ "one", "two" ])
                                -- UNNEST  |PARTITIONED|
                                  empty-tuple-source
                                  -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
